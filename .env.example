# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NVIDIA OpenAI-compatible chat endpoint for local AI panel requests.
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="deepseek-ai/deepseek-v4-pro"

# Firebase Authentication and Firestore.
NEXT_PUBLIC_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="MY_PROJECT.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="MY_PROJECT"
NEXT_PUBLIC_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="MY_PROJECT.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="MY_MEASUREMENT_ID"
